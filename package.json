    "lint": "npm run lint:back && npm run lint:front",
    "lint:back": "eslint \"server/**/*.js\"",
    "lint:front": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint . --fix",
    "clean:logs": "rm -rf ./logs/*.log"
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "hbs": "~4.0.4",
    "http-errors": "~1.6.3",
    "morgan": "~1.9.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.2"
  },
  "imports": {

  "type": "module",
  "private": true,
  "scripts": {
    "start": "NODE_ENV=production node ./server/bin/www",
    "dev": "DEBUG=dwssr:* nodemon ./server/bin/www",
    "dev:vite": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:vite\"",
